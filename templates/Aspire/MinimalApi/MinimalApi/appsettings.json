{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": []
//#if (applicationInsights)
  ,
  // Application Insights connection string.
  // For production and Azure deployments, set via the APPLICATIONINSIGHTS_CONNECTION_STRING
  // environment variable instead of storing it here. Aspire injects this automatically when
  // you use --applicationInsights and deploy with `aspire publish`.
  "ApplicationInsights": {
    "ConnectionString": ""
  }
//#endif
}
