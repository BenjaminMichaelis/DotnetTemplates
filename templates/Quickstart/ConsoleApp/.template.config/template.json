{
  "$schema": "http://json.schemastore.org/template",
  "author": "BenjaminMichaelis",
  "classifications": [
    "Common",
    "Quickstart",
    "ConsoleApp"
  ],
  "identity": "BenjaminMichaelis.Quickstart.ConsoleApp",
  "name": "Benjamin Michaelis Console Application",
  "shortName": "bmichaelis.quickstart.consoleapp",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory":true,
  "sourceName": "ConsoleApp",
  "symbols":{
    "createdDate": {
      "type": "generated",
      "generator": "now",
      "parameters": {
      "format": "yyyy"
      },
      "replaces":"1970"
    },
    "user_secrets_id":{
      "type": "generated",
      "generator": "guid",
      "replaces": "12345678-9abc-0123-4567-890abcdef123",
      "parameters": {
        "defaultFormat":"d"
      }
    },
    "no-sln": {
      "type": "parameter",
      "dataType":"bool",
      "defaultValue": "false",
      "description": "Do not include a solution file."
    },
    "tests": {
      "type": "parameter",
      "dataType":"choice",
      "defaultValue":"tunit",
      "description":"Test framework to include.",
      "choices":[
        {
          "choice":"tunit",
          "description":"Use TUnit tests"
        },
        {
          "choice":"xunit",
          "description":"Use xUnit v3 tests with MTP v2"
        },
        {
          "choice":"None",
          "description":"Do not include a test project"
        }
      ]
    },
    "USE_XUNIT": {
      "type": "computed",
      "value": "(tests == \"xunit\")"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(no-sln)",
          "exclude": [
            "ConsoleApp.slnx"
          ]
        },
        {
          "condition": "(tests == \"None\")",
          "exclude": [
            "ConsoleApp.Tests/*"
          ]
        }
      ]
    }
  ]
}
